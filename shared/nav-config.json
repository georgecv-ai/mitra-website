    "org": [
      {"label": {"en": "Dashboard",  "ko": "대시보드"},    "href": "{{app_base}}/{{lang}}/org/"},
      {"label": {"en": "Classes",    "ko": "수업"},        "href": "{{app_base}}/{{lang}}/org/classes"},
      {"label": {"en": "Students",   "ko": "학생"},        "href": "{{app_base}}/{{lang}}/org/students"},
      {"label": {"en": "Files",      "ko": "파일"},        "href": "{{app_base}}/{{lang}}/org/files"},
      {"label": {"en": "Chat Mitra", "ko": "미트라 채팅"}, "href": "{{app_base}}/{{lang}}/org/chat"},
      {"label": {"en": "Analytics",  "ko": "분석"},        "href": "{{app_base}}/{{lang}}/org/analytics"},
      {"label": {"en": "Sign Out",   "ko": "로그아웃"},    "href": "{{app_base}}/{{lang}}/org/logout"}
